@{
	ViewData["Title"] = "Danh Sách Công Đoạn Lưu Hóa Thành Hình MHE";
}

@using X.PagedList
@model IPagedList<AspnetCoreMvcFull.ModelDTO.Product.LuuHoaMHEDTO>

<div class="d-flex justify-content-between">
	<a asp-controller="LuuhoaMHE"
	   asp-action="CreateLHMHE"
	   style="background:#428BCA; border:#428BCA solid 1px; color:white; padding:6px; font-size:14px; border-radius:5px; text-decoration: none;">
		Thêm Mới
	</a>

	<form asp-controller="LuuhoaMHE"
		  asp-action="ListLuuhoa"
		  method="get"
		  style="display: flex; align-items: center; margin-right: 20px;">
		<div style="display: inline-flex; border: 1px solid #ccc; border-radius: 2px; overflow: hidden;">
			<input type="hidden" name="page" value="1" />

			<input type="text"
				   name="searchName"
				   placeholder="Nhập tên sản phẩm để tìm kiếm"
				   value="@Context.Request.Query["searchName"]"
				   style="border: none; padding: 5px 8px; font-size: 14px; width: 250px; height: 30px; outline: none;" />

			<button type="submit"
					style="padding: 5px 12px; background-color: #428BCA; color: white; border: none; cursor: pointer; font-size: 14px; height: 30px; outline: none;">
				Tìm kiếm
			</button>
		</div>
	</form>
</div>

<div class="container mt-4">
	@if (Model == null || !Model.Any())
	{
		<div class="alert alert-warning">Không có sản phẩm nào tên này.</div>
	}
	else
	{
		<div class="row">
			@foreach (var product in Model)
			{
				<div class="col-12 col-sm-6 col-md-4 mb-4">
					<div class="card text-center custom-card" style="border: 2px solid #a1a3a5; display: flex; flex-direction: column;">
						<div class="image-container">
							<img class="card-img-top mx-auto custom-image"
								 src="@Url.Content("~/images/" + (string.IsNullOrEmpty(product.image) ? "no-image.jpg" : product.image))"
								 alt="@product.name">

							<div class="button-container">
								<a asp-controller="LuuhoaMHE"
								   asp-action="EditLHMHE"
								   asp-route-id="@product.ProductId"
								   style="background:#428BCA; border:#428BCA solid 1px; color:white; padding:2px; font-size:9px; border-radius:5px; text-decoration: none;">
									<i class='bx bx-edit'></i>
								</a>

								<button type="button"
										onclick="deleteProduct(@product.ProductId)"
										style="margin: 0px; padding:3px; background: #B74635; color: white; border: #B74635; border-radius: 4px;">
									<i class="bx bx-trash-alt"></i>
								</button>
							</div>
						</div>

						<div class="card-body-title"
							 data-bs-toggle="modal"
							 data-bs-target="#modalScrollable"
							 onclick="loadProduct(@product.ProductId)"
							 style="margin-top: auto; cursor: pointer;">
							<p class="custom-title">@product.name</p>
						</div>
					</div>
				</div>
			}
		</div>

		<!-- Hiển thị phân trang -->
		<div class="pagination">
			@if (Model.PageCount > 1)
			{
				@if (Model.HasPreviousPage)
				{
					<a href="@Url.Action("ListLuuhoa", new { page = Model.PageNumber - 1, searchName = Context.Request.Query["searchName"] })">&laquo;</a>
				}

				@for (int i = 1; i <= Model.PageCount; i++)
				{
					if (i == Model.PageNumber)
					{
						<a href="#" class="active">@i</a>
					}
					else
					{
						<a href="@Url.Action("ListLuuhoa", new { page = i, searchName = Context.Request.Query["searchName"] })">@i</a>
					}
				}

				@if (Model.HasNextPage)
				{
					<a href="@Url.Action("ListLuuhoa", new { page = Model.PageNumber + 1, searchName = Context.Request.Query["searchName"] })">&raquo;</a>
				}
			}
		</div>
	}
</div>

<div class="modal fade" id="modalScrollable" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-fullscreen">
		<div class="modal-content" style="height: 100%; border-radius: 0;">
			<div class="modal-body p-0" id="modalBody" style="text-align:center; height: 100%; overflow: auto;">
			</div>
			<div class="modal-footer justify-content-center" style="position: fixed; bottom: 0; right: 0; z-index: 1050;">
				<button type="button" class="btn btn-sm btn-primary" data-bs-dismiss="modal" onclick="exitFullscreen()">Đóng</button>
			</div>
		</div>
	</div>
</div>

<script>
	function deleteProduct(productId) {
		if (confirm("Bạn có chắc chắn muốn xóa sản phẩm này không?")) {
			$.ajax({
				url: '@Url.Action("DeleteProductLHMHE", "LuuhoaMHE")',
				type: 'POST',
				data: { ProductId: productId },
				success: function () {
					alert("Sản phẩm đã được xóa thành công!");
					location.reload();
				},
				error: function (xhr) {
					alert("Có lỗi xảy ra: " + (xhr.responseText || "Không thể xóa"));
				}
			});
		}
	}

	function loadProduct(productId) {
		$.ajax({
			url: '@Url.Action("showProductLHMHE", "LuuhoaMHE")',
			type: 'GET',
			data: { id: productId },
			success: function (data) {
				$('#modalBody').html(data);
				$('#modalScrollable').modal('show');

				$('#modalScrollable').on('shown.bs.modal', function () {
					const modalElement = document.querySelector('#modalScrollable .modal-dialog');
					if (modalElement.requestFullscreen) {
						modalElement.requestFullscreen().catch(err => {
							console.log('Lỗi kích hoạt full màn hình:', err);
						});
					}
				});
			},
			error: function () {
				alert('Có lỗi xảy ra khi tải dữ liệu sản phẩm.');
			}
		});
	}

	function exitFullscreen() {
		if (document.exitFullscreen) {
			document.exitFullscreen();
		}
	}
</script>
